    "# Stressed VaR & Scenario Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "0ba9d73b",
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "import numpy as np\n",
    "\n",
    "# simulate returns\n",
    "returns = np.random.normal(0,0.02,1000)\n",
    "\n",
    "# stressed period (worst 100)\n",
    "stress = np.sort(returns)[:100]\n",
    "\n",
    "var = np.percentile(returns,1)\n",
    "svar = np.percentile(stress,1)\n",
    "\n",
    "print(\"VaR:\",var)\n",
    "print(\"sVaR:\",svar)\n"
   ]
  }
 ],
