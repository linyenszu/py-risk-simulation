   "source": [
    "\n",
    "import plotly.express as px\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "data = np.random.normal(0,1,1000)\n",
    "df = pd.DataFrame({'returns':data})\n",
    "\n",
    "fig = px.histogram(df, x='returns', nbins=50, title=\"Return Distribution\")\n",
    "fig.show()\n"
   ]
  }
