    "# Portfolio Aggregation (Desk → Unit)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "fa77a87f",
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "import pandas as pd\n",
    "\n",
    "df = pd.DataFrame({\n",
    "    'Portfolio':['P1','P1','P2','P2'],\n",
    "    'Desk':['Equity','Equity','FX','FX'],\n",
    "    'Unit':['UnitA','UnitA','UnitB','UnitB'],\n",
    "    'NPV':[100,200,150,-50]\n",
    "})\n",
    "\n",
    "agg = df.groupby(['Unit','Desk']).sum()\n",
    "agg\n"
   ]
  }
 ],
